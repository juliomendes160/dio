.rccs { perspective: 1000px; }

.rccs, .rccs__card { margin: 0px auto; width: 290px; }

.rccs__card { height: 182.873px; position: relative; transform-style: prese=
rve-3d; transition: 0.4s linear; }

.rccs__card--back, .rccs__card--front { backface-visibility: hidden; backgr=
ound: linear-gradient(25deg, rgb(147, 147, 147), rgb(113, 113, 113)); borde=
r-radius: 14.5px; box-shadow: rgba(0, 0, 0, 0.2) 0px 0px 20px; color: rgb(2=
55, 255, 255); height: 100%; left: 0px; overflow: hidden; position: absolut=
e; top: 0px; transform-style: preserve-3d; width: 100%; }

.rccs__card--front { z-index: 20; }

.rccs__card--back { transform: rotateY(180deg); }

.rccs__card--back .rccs__issuer { background-position: center bottom; inset=
: auto auto 5% 50%; opacity: 0.6; transform: translateX(-50%); }

.rccs__card__background { height: 200%; left: -170%; position: absolute; to=
p: -60%; transform: rotate(25deg); transition: 0.5s ease-out; width: 150%; =
}

.rccs__card--flipped { transform: rotateY(180deg); }

.rccs__card--flipped .rccs__card--front { z-index: 10; }

.rccs__card--flipped .rccs__card--back { z-index: 20; }

.rccs__card--unknown > div { background: linear-gradient(25deg, rgb(153, 15=
