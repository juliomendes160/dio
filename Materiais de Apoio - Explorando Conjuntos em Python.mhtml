.author__common { align-items: center; display: flex; }

.author__common--name { color: rgb(255, 255, 255); font-size: 1rem; font-we=
ight: 700; margin: 0px; }

.author__info { color: rgba(255, 255, 255, 0.5); margin: 0px; padding: 15px=
 0px; }

.author__country { align-items: center; display: flex; }

.author__country--flag { margin-right: 5px; width: 24px; }

.author__country--name { margin: 0px 0px 0px 5px; }

.comment-card .vote-control .btn .fa { color: rgb(152, 152, 158); font-size=
: 1.6rem; }

.comment-card .vote-control .btn .fa.selected { color: rgb(26, 255, 26) !im=
portant; }

.comment-card .vote-control .btn:hover .fa { color: rgb(255, 255, 255); }

.comment-card .vote-control .btn:hover .fa.selected { color: rgb(26, 255, 2=
6) !important; }

.comment-card .vote-control span { background-color: rgb(46, 52, 59) !impor=
tant; color: rgb(255, 255, 255); }

.comment-card .vote-control .voted .btn .fa { color: rgb(241, 193, 66) !imp=
ortant; }

.comment-card .img-fluid { border-radius: 50%; }

.comment-card .btn-light { background-color: rgb(255, 255, 255); border-col=
or: rgb(255, 255, 255); color: rgb(35, 40, 44); }

.comment-card .btn-light:hover { background-color: rgb(226, 230, 234); bord=
er-color: rgb(218, 224, 229); color: rgb(33, 37, 41); }

.comment-card .btn-light:focus { background-color: rgb(255, 255, 255); bord=
er-color: rgb(255, 255, 255); color: rgb(35, 40, 44); }

.comment-card .topic-content pre { background-color: rgb(0, 0, 0); color: r=
gb(255, 255, 255); padding: 0.5rem 0.8rem; }

.comment-card__main { height: calc(-200px + 100vh); overflow: auto; }

.comment-card__skills, .comment-card__title { margin-bottom: 16px; }

.comment-card__header { padding: 32px 42px; border: none !important; }

.comment-card__avatar-with-name { font-weight: 700; }

.comment-card__info { margin-left: 10px; }

.comment-card__name { font-weight: 700; }

.comment-card__date { color: rgba(255, 255, 255, 0.5); }

.comment-card__content { padding: 32px 42px; }

.comment-card__jumbotron { align-items: center; border-radius: 0.3rem; colo=
r: rgb(255, 255, 255); display: flex; justify-content: space-evenly; paddin=
g: 1rem 0px; }

.comment-card__comment-area { padding: 15px; }

.reply-box-editor .quill .ql-tooltip::before { color: rgb(152, 153, 157); }

.reply-box-editor .quill .ql-preview { color: rgb(152, 153, 157) !important=
; }

.reply-box-editor .quill .ql-action::after, .reply-box-editor .quill .ql-re=
move::before { color: rgb(152, 153, 157); }

.article-card .card-img-top { max-height: 250px; object-fit: cover; object-=
position: center top; }

.articles .skills-filter { padding-inline-start: 0px; }

.articles .skills-filter li { list-style: none; }

.articles .skills-filter li a:hover { cursor: pointer; text-decoration: non=
e; }

.articles .skills-filter li span:hover { cursor: pointer; }

.articles .articles-feed-type h5 { border-bottom: 3px solid rgba(0, 0, 0, 0=
); }

.articles .articles-feed-type h5.active { border-bottom: 3px solid rgb(255,=
 255, 255); }

.comment-card img { width: 100%; }

.documentation { margin-top: 50px; padding-top: 55px; }

.documentation__content { background: rgb(19, 20, 27); border-radius: 5px; =
padding: 15px; }

.documentation a { color: rgb(255, 255, 255); text-decoration: underline; }

@media (min-width: 768px) {
  .documentation__content { padding: 64px 32px !important; }
