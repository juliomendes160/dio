{
    "terminal.integrated.profiles.windows": {

        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell",
            "args": ["-noexit", "-command", "${workspaceFolder}\\.ps1\\.ps1"]
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": ["/k", "${workspaceFolder}\\.bat\\.bat"],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash",
            "args": ["--init-file", "${workspaceFolder}\\.bash\\.bash"]
        }
    }
}